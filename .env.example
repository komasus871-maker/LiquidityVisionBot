BOT_TOKEN=replace_with_botfather_token
BOT_MODE=webhook
WEBHOOK_BASE_URL=https://YOUR-SERVICE.onrender.com

# Persistent production database. Required on Render when
# REQUIRE_PERSISTENT_DB=true.
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require
PGSSLMODE=require
REQUIRE_PERSISTENT_DB=true
DB_CONNECT_TIMEOUT=15

# Free Render cannot run loops while asleep. Configure an external cron to:
# GET /internal/monitor?token=YOUR_SECRET every 5 minutes.
MONITOR_CRON_SECRET=replace_with_a_long_random_secret

SIGNAL_CHECK_INTERVAL=60
OBSERVATION_CHECK_INTERVAL=300
WATCHLIST_CHECK_INTERVAL=300
WATCHLIST_MONITOR_CONCURRENCY=4
WATCHLIST_SCORE_DELTA=12
WATCHLIST_READINESS_DELTA=12
ANALYSIS_CONCURRENCY=2
SCANNER_CONCURRENCY=4
SCANNER_CACHE_TTL=30

PREMIUM_STARS=199
PREMIUM_DAYS=30
DATA_DIR=data

# Trade Lifecycle 2.0
AUTO_BREAK_EVEN_AFTER_TP1=true
TRADE_PROGRESS_INTERVAL=900
TRADE_PROGRESS_STEP=20
