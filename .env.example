BOT_TOKEN=replace_with_your_new_botfather_token
DATA_DIR=data

OBSERVATION_CHECK_INTERVAL=300

# Render Web Service health endpoint
# Render injects PORT automatically; local default is 10000.
HEALTH_HOST=0.0.0.0
HEALTH_PORT=10000

# Personal watchlist autonomous monitor
WATCHLIST_CHECK_INTERVAL=300
WATCHLIST_MONITOR_CONCURRENCY=4
WATCHLIST_SCORE_DELTA=12
WATCHLIST_READINESS_DELTA=12
