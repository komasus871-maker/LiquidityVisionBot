BOT_TOKEN=replace_with_your_new_botfather_token
DATA_DIR=data

OBSERVATION_CHECK_INTERVAL=300

# Render Web Service health endpoint
# Render injects PORT automatically; local default is 10000.
HEALTH_HOST=0.0.0.0
HEALTH_PORT=10000

# Persistent database (recommended on Render).
# Use a PostgreSQL connection string from Neon, Supabase, Render Postgres, etc.
# Without DATABASE_URL the bot falls back to local SQLite, which can reset on free Render.
DATABASE_URL=
PGSSLMODE=require

# Optional protected endpoint for external cron wake-ups:
# GET/POST https://YOUR-SERVICE.onrender.com/internal/monitor?token=YOUR_SECRET
MONITOR_CRON_SECRET=replace_with_a_long_random_secret
